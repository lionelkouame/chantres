parameters:
    level: 10
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
    excludePaths:
        - tests/bootstrap.php
    ignoreErrors:
        - # public/index.php — $context values are mixed by design in the Symfony runtime
            message: '#Parameter \#1 \$environment of class App\\Kernel constructor expects string, mixed given\.#'
            path: public/index.php
includes:
  - vendor/phpstan/phpstan-symfony/extension.neon

services:
  - PHPStan\Rules\Symfony\ContainerInterfaceUnknownServiceRule
